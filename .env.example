# MainCharacter — Environment Variables (EXAMPLE — no real values)
# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Set the real values in the Render dashboard, not in a committed file.

# ─── Core ───
NODE_ENV=production
PORT=3000

# WATI_* env vars removed in Night 3 migration. See DECISIONS.md.
# WhatsApp now goes direct through the Meta Cloud API; SMS via MSG91; email via Resend.

# ─── Google Gemini (scoring + assessments) ───
GEMINI_API_KEY=

# ─── WhatsApp Cloud API (Meta) — Orator channel ───
# DORMANT until these are set: every send is a logged DRY-RUN. See
# WHATSAPP_CLOUD_API_SETUP.md for how to obtain each value.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Meta app secret — verifies incoming webhooks via x-hub-signature-256.
# Until set, unsigned webhooks are accepted (boot warns).
WHATSAPP_APP_SECRET=
# Random string echoed during Meta's webhook GET handshake. Must match the value
# entered in the Meta App webhook config. (A UUID was generated in BACKLOG.md.)
WHATSAPP_VERIFY_TOKEN=
# Outgoing send mode (governs WhatsApp, SMS and email): all | allowlist | off
#   all       = send to everyone (normal production)
#   allowlist = send only to ADMIN_PHONE / ADMIN_EMAIL + extras (DEFAULT — safe)
#   off       = dry-run, never call any provider API
WHATSAPP_SEND_MODE=allowlist
# Extra comma-separated numbers allowed when WHATSAPP_SEND_MODE=allowlist
WHATSAPP_ALLOWLIST=

# ─── MSG91 (SMS / OTP) — Lookmaxxing PWA login + SMS fallback ───
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID_OTP=
MSG91_SENDER_ID=MAINCH

# ─── Resend (email) — receipts, Day-7 reports, audit confirmations ───
RESEND_API_KEY=
RESEND_FROM_EMAIL=consultant@maincharacter.digitglobalservices.com

# ─── Admin ───
# Founder WhatsApp for alerts (country code, no +). Also the allowlist owner.
ADMIN_PHONE=
# Multi-admin allowlist (Night-4): comma-separated normalised phones. Preferred
# over ADMIN_PHONE; the singular var is kept as a fallback. e.g. 918595833852,919876543210
ADMIN_PHONES=
# Founder email for alerts + the email-allowlist owner.
ADMIN_EMAIL=
# Multi-admin emails (Night-4): comma-separated; falls back to ADMIN_EMAIL.
ADMIN_EMAILS=
# Extra comma-separated emails allowed when WHATSAPP_SEND_MODE=allowlist
EMAIL_ALLOWLIST=
# bcrypt hash of the admin password (see lib/auth.js helper to generate one).
ADMIN_PASSWORD_HASH=
# Secret used to sign admin JWTs (HS256). Use a long random string.
ADMIN_JWT_SECRET=

# ─── Razorpay ───
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Flip to true to use recurring Subscriptions instead of one-shot links
RAZORPAY_SUBSCRIPTIONS_ENABLED=false
# Night-4 safety gate: keep false until the founder validates dogfood. While
# false, /paywall serves a waitlist page and NO Razorpay flow is reachable.
PAYWALL_PUBLIC=false

# ─── PWA push (Lookmaxxing) — optional, no-op if unset ───
WEB_PUSH_VAPID_PUBLIC=
WEB_PUSH_VAPID_PRIVATE=

# ─── Lookmaxxing PWA auth ───
# JWT signing secret for the Lookmaxxing-scoped tokens (falls back to ADMIN_JWT_SECRET).
JWT_SECRET=

# ─── URLs ───
UPGRADE_BASE_URL=https://maincharacter.digitglobalservices.com

# ─── Optional integrations (no-op if unset) ───
DATABASE_URL=
REDIS_URL=
SENTRY_DSN=
AXIOM_TOKEN=

# ─── Scheduler ───
# Set to false on the web dyno once a dedicated worker runs the cron
RUN_SCHEDULER=true
